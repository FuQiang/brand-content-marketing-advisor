##############################################################################
# brand-content-marketing-advisor — 配置模板
#
# 首次安装时复制本文件为 config.yaml：
#   cp config.yaml.template config.yaml
#
# 所有 app_token / table_id 留空即可。首次运行会自动：
#   1. 创建新的飞书多维表格（Bitable）
#   2. 在其中创建全部 6 张表并初始化字段
#   3. 回写生成的 app_token 和 table_id 到 config.yaml
#
# 也可通过环境变量 BCMA_APP_TOKEN 指定已有的 Bitable。
##############################################################################

app:
  # 留空：首次运行自动创建 Bitable 并回写；之后永远复用。
  # 也可通过环境变量 BCMA_APP_TOKEN 覆盖。
  app_token: ""

tables:
  # 留空：首次运行自动建表并回写 table_id。
  brands:
    table_id: ""
  brand_audience:
    table_id: ""
  products:
    table_id: ""
  brand_topic_rules:
    table_id: ""
  topic_selection:
    table_id: ""
  content_matrix:
    table_id: ""

fields:
  # Brand 表：品牌基础信息（7 个维度，由用户手工维护）
  brands:
    name: "品牌名称"
    category_price: "品类与价格带"
    differentiation: "核心差异化"
    competitors: "最大竞品"
    excluded_audience: "排斥人群"
    compatible_persona: "适配人设/美学"
    conflict_persona: "冲突人设/美学"
    high_value_scenes: "高价值场景"
  # 品牌人群表：基于 Brand 表自动 LLM 生成，所有字段不能为空
  brand_audience:
    name: "品牌名称"
    audience: "典型人群受众"
    persona_tags: "画像标签"
    motivation: "消费动机"
    content_preference: "内容偏好"
    persona_description: "人群描述"
  products:
    brand: "所属品牌"
    series: "产品系列"
    name: "产品名称"
    selling_point: "产品卖点"
    selling_point_detail: "卖点详细阐述"
    persona_tags: "目标人群标签"
    pain_points: "人群痛点"
    season: "季节"
    price_band: "价格带"
    material: "材质"
    functions: "功能点"
    base_weight: "基础权重"
    asset_gallery_field: "产品图库(真实大片)"
    non_removable_fields:
      - "所属品牌"
      - "产品名称"
      - "产品系列"
      - "产品卖点"
      - "目标人群标签"
      - "功能点"
      - "季节"
      - "产品图库(真实大片)"
  brand_topic_rules:
    name: "品牌名称"
    rules_prompt: "话题筛选及评估逻辑"
  topic_selection:
    topic: "话题名称"
    brand: "适用品牌"
    audience: "适用人群"
    r1: "R1 相关度"
    r2: "R2 场景力"
    r3: "R3 流量趋势"
    r4: "R4 舆情风险"
    total_score: "总分"
    decision: "决策结果"
    one_line_reason: "一句话理由"
    content_direction: "内容方向建议"
    created_at: "入库时间"
    source: "来源"
    fetched_at: "抓取时间"
    rule_hits: "规则命中说明"
    raw_text: "原始文本"
  content_matrix:
    topic: "匹配话题"
    brand: "适用品牌"
    audience: "目标人群"
    products: "主推产品"
    platforms: "适用平台"
    hook: "爆款标题/钩子"
    body: "正文与脚本"
    visuals: "视觉画面建议"
    logic_breakdown: "爆款逻辑拆解(为什么会火)"
    douyin_script: "抖音短视频脚本"
    douyin_cover: "抖音封面(9:16)"
    xhs_title: "小红书标题"
    xhs_note: "小红书种草笔记"
    xhs_cover: "小红书封面(3:4)"
    cover_image_ai_field: "视频封面(AI生成)"
    video_asset_ai: "视频素材(AI生成)"
    generated_at: "生成时间"
    source_topic_id: "来源话题ID"
    idempotent_key: "幂等键"

scoring:
  relevance_weight: 0.25
  resonance_weight: 0.25
  reach_weight: 0.25
  revenue_weight: 0.25
  threshold_main: 16
  threshold_candidate: 13
  r4_veto_threshold: 2

regex_filters:
  blacklist_patterns:
    - "政治"
    - "赌博"
    - "违法"
  whitelist_patterns: []
  allow_patterns: []

concurrency:
  max_workers: 8
  request_timeout_seconds: 10
  max_retries: 2
  backoff_factor: 2.0

model:
  provider: "doubao"
  model_name: "doubao-pro-32k"
  temperature: 0.8
  top_p: 0.9
  max_tokens: 4096
  candidates:
    - provider: "anthropic"
      model_name: "claude-opus-4-6"
      enabled: true
    - provider: "anthropic"
      model_name: "claude-sonnet-4-6"
      enabled: true
    - provider: "doubao"
      model_name: "doubao-pro-32k"
      enabled: true

downstream:
  default_platforms:
    - "小红书"
    - "抖音"
  max_products_per_topic: 2
  brand_topic_lookback_hours: 48
  brand_top_k_assets: 5

# 第五步：每日精选话题筛选数据源（跨 base 读取）
# 必须配置：这是 Step 5 的外部数据源，指向你自己维护的「每日精选话题」表。
# 如果留空，Step 5 会返回友好提示而非报错。
daily_topics:
  # 目标 base 的 app_token（来自飞书多维表格 URL）
  app_token: ""
  table_id: ""
  view_id: ""
  # 当日时间窗口时区（北京时间 UTC+8）
  timezone_offset_hours: 8
  # Top K: select_topic 一次性取前 K 条高分话题写入 TopicSelection
  top_k: 5
  # 字段映射（根据你的每日精选话题表实际列名调整）
  fields:
    topic: "话题"
    source: "平台"
    created_at: "日期"
    fetched_at: "日期"
    raw_text: ""
    category: "归类"
    content_direction: "承接方向"
    suggested_action: "建议动作"
    target_audience: "目标人群"
    heat: "今日热度"
    heat_delta: "日增幅"
    rising_days: "连涨天数"
